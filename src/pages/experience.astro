---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
  <Navbar />
  <main class="pt-32 px-6 max-w-4xl mx-auto pb-20">
    <h1 class="text-4xl font-bold mb-10 pl-2">Experience</h1>

    <div class="space-y-8">
      {/* IIT BHU Internship */}
      <div
        class="group rounded-3xl p-10 liquid-glass hover:frosty-glass transition-all duration-500"
      >
        <div
          class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-2"
        >
          <div>
            <h2
              class="text-2xl font-bold text-white group-hover:text-glow transition-all"
            >
              Organizer
            </h2>
            <h3 class="text-lg text-white/70">
              CrftHQ
            </h3>
          </div>
          <span
            class="px-4 py-1 rounded-full border border-white/10 bg-white/5 text-sm text-white/60 whitespace-nowrap"
          >
            Feb 2025 - Sept 2025
          </span>
        </div>

        <ul class="space-y-4 text-white/70">
          <li class="flex gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-white/50 shrink-0"
            ></span>
            <p>
              Co-organized a startup accelerator supporting 100 early-stage teams through structured mentorship and evaluation phases.
            </p>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-white/50 shrink-0"
            ></span>
            <p>
            Coordinated program operations including mentor onboarding, session scheduling, and progress tracking.
            </p>
          </li>
        </ul>
      </div>
    </div>
  </main>
</Layout>
