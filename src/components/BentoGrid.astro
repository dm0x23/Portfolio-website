---
const techStack = [
  "Rust",
  "Go",
  "C++",
  "Python",
  "TypeScript",
  "React",
  "Astro",
  "Tensorflow",
];

const projects = [
  {
    title: "Gosh",
    description: "A high-performance UNIX-like shell",
    stack: ["Go", "Systems", "Docker", "GitHub Releases"],
    link: "/gosh",
  },
  {
    title: "F1 Tire Degradation",
    description: "Machine learning model to predict F1 tire degradation",
    stack: ["Python", "Machine Learning", "Data Science"],
    link: "https://github.com/dm0x23/f1-tire-degradation",
  },
  {
    title: "Self-Driving Car",
    description:
      "A car driving game automated using custom-made neural networks",
    stack: ["JavaScript"],
    link: "https://github.com/dm0x23/Self-Driving-Car",
  },
];
---

<section
  class="max-w-7xl mx-auto px-6 pt-10 pb-32 grid grid-cols-1 md:grid-cols-6 lg:grid-cols-4 gap-4 auto-rows-[minmax(180px,auto)]"
>
  {/* 1. Main Introduction Tile */}
  <div
    class="col-span-1 md:col-span-3 lg:col-span-2 row-span-1 rounded-3xl p-8 flex flex-col justify-between transition-all duration-500 group liquid-glass hover:frosty-glass min-h-[200px]"
  >
    <div class="flex flex-col gap-2">
      <h1
        class="text-2xl md:text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-white/60 leading-tight"
      >
        Summary
      </h1>
      <p class="text-white/60 text-base leading-relaxed">
        19-year-old developer based in Chennai, India. <br />
        Drawn to the layer where software meets the metal. <br />
        Building systems with Go and Rust, and exploring AI models from scratch.
      </p>
    </div>
  </div>

  {/* 2. Tech Stack Tile */}
  <div
    class="col-span-1 md:col-span-3 lg:col-span-2 row-span-1 rounded-3xl p-8 flex flex-col justify-center transition-all duration-500 group liquid-glass hover:frosty-glass min-h-[200px]"
  >
    <h3
      class="text-white/40 text-sm font-semibold uppercase tracking-widest mb-6"
    >
      Core Stack
    </h3>
    <div class="flex flex-wrap gap-2">
      {
        techStack.map((tech) => (
          <span class="px-3 py-1.5 text-xs md:text-sm rounded-lg border border-white/10 bg-white/5 text-white/70 hover:bg-purple-500/20 hover:border-purple-500/50 hover:text-white transition-all duration-300 cursor-default">
            {tech}
          </span>
        ))
      }
    </div>
  </div>

  {/* 3. Portfolio */}
  <a
    href={projects[1].link}
    target="_blank"
    class="col-span-1 md:col-span-3 lg:col-span-2 row-span-1 rounded-3xl p-8 flex flex-col justify-between transition-all duration-500 group liquid-glass hover:frosty-glass cursor-pointer min-h-[300px]"
  >
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3 class="text-2xl font-bold text-white mb-1">{projects[1].title}</h3>
        <p class="text-white/50 text-sm">{projects[1].description}</p>
      </div>
      <div
        class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="7" y1="17" x2="17" y2="7"></line><polyline
            points="7 7 17 7 17 17"></polyline></svg
        >
      </div>
    </div>

    <div
      class="rounded-2xl overflow-hidden border border-white/10 shadow-lg mb-4"
    >
      <video loop muted playsinline preload="auto" onmouseenter="this.play()" onmouseleave="this.pause()" class="w-full object-cover">
        <source src="/f1-tire-degradation.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="flex flex-wrap gap-2 mt-auto">
      {
        projects[1].stack.map((t) => (
          <span class="px-2 py-1 text-xs rounded-md border border-white/10 bg-white/5 text-white/60 group-hover:bg-purple-500/10 group-hover:border-purple-500/30 transition-colors">
            {t}
          </span>
        ))
      }
    </div>
  </a>

  {/* 4. Project 1: Gosh */}
  <a
    href={projects[0].link}
    target="_blank"
    class="col-span-1 md:col-span-3 lg:col-span-2 row-span-1 rounded-3xl p-8 flex flex-col justify-between transition-all duration-500 group liquid-glass hover:frosty-glass cursor-pointer min-h-[300px]"
  >
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3 class="text-2xl font-bold text-white mb-1">Gosh</h3>
        <p class="text-white/50 text-sm">A high-performance UNIX-like shell</p>
      </div>
      <div
        class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="7" y1="17" x2="17" y2="7"></line><polyline
            points="7 7 17 7 17 17"></polyline></svg
        >
      </div>
    </div>

    <div
      class="rounded-2xl overflow-hidden border border-white/10 shadow-lg mb-4"
    >
      <video loop muted playsinline preload="auto" onmouseenter="this.play()" onmouseleave="this.pause()" class="w-full object-cover">
        <source src="/gosh.webm" type="video/webm" />
      </video>
    </div>

    <div class="flex flex-wrap gap-2 mt-auto">
      {
        projects[0].stack.map((t) => (
          <span class="px-2 py-1 text-xs rounded-md border border-white/10 bg-white/5 text-white/60 group-hover:bg-purple-500/10 group-hover:border-purple-500/30 transition-colors">
            {t}
          </span>
        ))
      }
    </div>
  </a>

  {/* 5. Project 3: Neural Engine */}
  <a
    href={projects[2].link}
    target="_blank"
    class="col-span-1 md:col-span-3 lg:col-span-2 row-span-1 rounded-3xl p-8 flex flex-col justify-between transition-all duration-500 group liquid-glass hover:frosty-glass cursor-pointer min-h-[300px]"
  >
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3 class="text-2xl font-bold text-white mb-1">Self-Driving Car</h3>
        <p class="text-white/50 text-sm">
          A car driving game automated using custom-made neural networks
        </p>
      </div>
      <div
        class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="7" y1="17" x2="17" y2="7"></line><polyline
            points="7 7 17 7 17 17"></polyline></svg
        >
      </div>
    </div>

    <div
      class="rounded-2xl overflow-hidden border border-white/10 shadow-lg mb-4"
    >
      <video loop muted playsinline preload="auto" onmouseenter="this.play()" onmouseleave="this.pause()" class="w-full object-cover">
        <source src="/selfdrivingcar.webm" type="video/webm" />
      </video>
    </div>

    <div class="flex flex-wrap gap-2 mt-auto">
      {
        projects[2].stack.map((t) => (
          <span class="px-2 py-1 text-xs rounded-md border border-white/10 bg-white/5 text-white/60 group-hover:bg-purple-500/10 group-hover:border-purple-500/30 transition-colors">
            {t}
          </span>
        ))
      }
    </div>
  </a>
</section>
